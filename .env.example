APP_NAME="Flight Aggregator API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=flight_aggregator
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# Flight providers — mock endpoints served by this same app.
FLIGHT_PROVIDER_A_URL=http://localhost:8000/mock/provider-a
FLIGHT_PROVIDER_B_URL=http://localhost:8000/mock/provider-b
FLIGHT_PROVIDER_C_URL=http://localhost:8000/mock/provider-c

# Per-provider HTTP timeout (seconds).
FLIGHT_PROVIDER_A_TIMEOUT=2
FLIGHT_PROVIDER_B_TIMEOUT=2
FLIGHT_PROVIDER_C_TIMEOUT=2

# Search result cache TTL (seconds).
FLIGHT_CACHE_TTL=60